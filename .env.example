# Environment Configuration
# This file contains only environment-specific variables (API keys, URLs, etc.)
# Application configuration should be in dedicated config files (see src/lib/crawler-config.ts)

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/smartplay"

# Node Environment (development, production, test)
NODE_ENV="development"

# Base URL (Optional, defaults to http://localhost:3000 in dev, https://smartplay.hk in prod)
# BASE_URL="http://localhost:3000"

# ============================================
# Docker Configuration
# ============================================
# These variables are specifically for Docker deployments
# See .env.docker.example for complete Docker setup
#
# Quick start with Docker:
# 1. Copy .env.docker.example to .env.docker
# 2. Update the values as needed
# 3. Run: docker compose up
# ============================================

# ============================================
# CI/CD Configuration (GitHub Actions)
# ============================================
# The following secrets are required for CI/CD deployment:
# See .github/workflows/README.md for detailed setup instructions
#
# Required Secrets:
# - DATABASE_URL: PostgreSQL connection string
# - DEPLOY_URL: Production application URL (for health checks)
# - SSH_PRIVATE_KEY: SSH private key for server access
# - SSH_HOST: Remote server hostname/IP
# - SSH_USER: SSH username
# - TURNSTILE_SITE_KEY: Cloudflare Turnstile site key
# - TURNSTILE_SECRET_KEY: Cloudflare Turnstile secret key
#
# Setup:
# 1. Go to repository Settings > Secrets and variables > Actions
# 2. Add each secret with its corresponding value
# 3. Push to main branch to trigger deployment
# ============================================

# ============================================
# Crawler Configuration
# ============================================
# Crawler settings are now configured in src/lib/crawler-config.ts
#
# To customize crawler behavior:
# 1. Edit src/lib/crawler-config.ts directly, OR
# 2. Use the updateCrawlerConfig() function at runtime
#
# Example:
# ```typescript
# import { updateCrawlerConfig } from './lib/crawler-config'
#
# updateCrawlerConfig({
#   enabled: true,
#   districts: ['KC', 'SSP'],
#   facilityType: 'TENC',
#   timeout: 60000
# })
# ```
#
# Default configuration:
# - Enabled: true
# - Interval: Every 30 minutes
# - Timezone: Asia/Hong_Kong
# - Districts: CW, EN, SN, WCH
# - Facility Type: TENC (Tennis Court)
# - Timeout: 30000ms (30 seconds)
# - Retry Attempts: 3
# ============================================

# ============================================
# Watch Scheduler Configuration
# ============================================
# Cloudflare Turnstile (required for bot protection)
# VITE_ prefix required for client-side access
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
CLOUDFLARE_TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

