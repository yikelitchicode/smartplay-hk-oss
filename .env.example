# Environment Configuration
# This file contains only environment-specific variables (API keys, URLs, etc.)
# Application configuration should be in dedicated config files (see src/lib/crawler-config.ts)

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/smartplay"

# Node Environment (development, production, test)
NODE_ENV="development"

# ============================================
# Crawler Configuration
# ============================================
# Crawler settings are now configured in src/lib/crawler-config.ts
#
# To customize crawler behavior:
# 1. Edit src/lib/crawler-config.ts directly, OR
# 2. Use the updateCrawlerConfig() function at runtime
#
# Example:
# ```typescript
# import { updateCrawlerConfig } from './lib/crawler-config'
#
# updateCrawlerConfig({
#   enabled: true,
#   districts: ['KC', 'SSP'],
#   facilityType: 'TENC',
#   timeout: 60000
# })
# ```
#
# Default configuration:
# - Enabled: true
# - Interval: Every 30 minutes
# - Timezone: Asia/Hong_Kong
# - Districts: CW, EN, SN, WCH
# - Facility Type: TENC (Tennis Court)
# - Timeout: 30000ms (30 seconds)
# - Retry Attempts: 3
# ============================================
