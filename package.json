{
	"name": "smartplay-hk-oss",
	"version": "0.1.0",
	"type": "module",
	"description": "Web application for tracking facility availability from LCSD in Hong Kong",
	"license": "CC-NC-SA-4.0",
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=10.0.0"
	},
	"keywords": [
		"sports",
		"booking",
		"hong-kong",
		"lcsd",
		"facilities",
		"crawler",
		"tanstack-start",
		"react"
	],
	"scripts": {
		"dev": "tsx scripts/dev.ts",
		"dev:vite": "vite dev --port 3000",
		"build": "node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js build",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:coverage": "vitest run --coverage",
		"test:crawler": "tsx scripts/test-crawler.ts",
		"format": "biome format",
		"lint": "biome lint --fix",
		"check": "biome check --fix",
		"typecheck": "tsc",
		"typecheck:watch": "tsc --watch",
		"clean": "rm -rf .output node_modules/.vite",
		"reinstall": "pnpm clean && pnpm install",
		"db:generate": "dotenv -e .env.local -- prisma generate",
		"db:push": "dotenv -e .env.local -- prisma db push",
		"db:migrate": "dotenv -e .env.local -- prisma migrate dev",
		"db:studio": "dotenv -e .env.local -- prisma studio",
		"db:seed": "dotenv -e .env.local -- prisma db seed",
		"db:reset": "dotenv -e .env.local -- prisma db push --force-reset",
		"db:validate": "dotenv -e .env.local -- prisma validate",
		"db:format": "dotenv -e .env.local -- prisma format"
	},
	"dependencies": {
		"@base-ui/react": "^1.1.0",
		"@prisma/adapter-pg": "^7.2.0",
		"@prisma/client": "^7.2.0",
		"@scalar/api-reference-react": "^0.8.27",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-devtools": "^0.9.2",
		"@tanstack/react-form": "^1.27.7",
		"@tanstack/react-query": "^5.90.19",
		"@tanstack/react-router": "^1.151.6",
		"@tanstack/react-router-devtools": "^1.151.6",
		"@tanstack/react-router-ssr-query": "^1.151.6",
		"@tanstack/react-start": "^1.153.0",
		"@tanstack/router-plugin": "^1.151.6",
		"chinese-conv": "^4.0.0",
		"date-fns": "^4.1.0",
		"i18next": "^25.7.4",
		"i18next-browser-languagedetector": "^8.2.0",
		"i18next-http-backend": "^3.0.2",
		"lucide-react": "^0.562.0",
		"nitro": "npm:nitro-nightly@3.0.1-20260119-111705-26241d6b",
		"node-cron": "^4.2.1",
		"p-queue": "^9.1.0",
		"pg": "^8.17.1",
		"pino": "^10.2.0",
		"pino-pretty": "^13.1.3",
		"prisma": "^7.2.0",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-i18next": "^16.5.3",
		"tailwindcss": "^4.1.18",
		"uuid": "^13.0.0",
		"vite-tsconfig-paths": "^6.0.4",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@tanstack/devtools-vite": "^0.4.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.0.9",
		"@types/node-cron": "^3.0.11",
		"@types/pg": "^8.16.0",
		"@types/react": "^19.2.8",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.2",
		"dotenv-cli": "^11.0.0",
		"jsdom": "^27.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.17",
		"web-vitals": "^5.1.0"
	}
}
