{
  "name": "smartplay-hk-oss",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint --fix",
    "check": "biome check --fix",
    "post-cta-init": "npx create-db@latest --user-agent tanstack/tsrouter",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- prisma db seed",
    "test:crawler": "tsx scripts/test-crawler.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.9.2",
    "@tanstack/react-router": "^1.147.3",
    "@tanstack/react-router-devtools": "^1.149.0",
    "@tanstack/react-router-ssr-query": "^1.147.3",
    "@tanstack/react-start": "^1.149.2",
    "@tanstack/router-plugin": "^1.149.0",
    "date-fns": "^4.1.0",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.562.0",
    "nitro": "npm:nitro-nightly@latest",
    "node-cron": "^4.2.1",
    "prisma": "^7.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.5.2",
    "tailwindcss": "^4.1.18",
    "vite-tsconfig-paths": "^6.0.4",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@tanstack/devtools-vite": "^0.4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.0.7",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^27.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.17",
    "web-vitals": "^5.1.0"
  }
