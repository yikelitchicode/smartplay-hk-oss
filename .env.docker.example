# Docker Environment Configuration
# Copy this file to .env.docker and customize for your deployment
# Usage: docker compose --env-file .env.docker up

# ============================================
# Application Configuration
# ============================================
NODE_ENV="production"
BASE_URL="http://localhost:3000"

# ============================================
# Database Configuration (for docker-compose)
# ============================================
# These settings match the defaults in docker-compose.yml
# Override if using external database
DATABASE_URL="postgresql://smartplay:smartplay_password@postgres:5432/smartplay"

# PostgreSQL Settings (for postgres service)
POSTGRES_VERSION="18-alpine"
POSTGRES_USER="smartplay"
POSTGRES_PASSWORD="smartplay_password"
POSTGRES_DB="smartplay"
POSTGRES_PORT="5432"

# ============================================
# Container Configuration
# ============================================
# Container names
POSTGRES_CONTAINER_NAME="smartplay-postgres"
APP_CONTAINER_NAME="smartplay-app"
CLOUDFLARED_CONTAINER_NAME="smartplay-cloudflared"

# Volume names
POSTGRES_VOLUME_NAME="smartplay_postgres_data"

# Port mappings (host:container)
APP_PORT="3000:3000"
POSTGRES_PORT="5432:5432"

# ============================================
# Cloudflare Turnstile (Bot Protection)
# ============================================
# Get your keys from: https://dash.cloudflare.com/
# Required for production deployments
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
CLOUDFLARE_TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# ============================================
# Cloudflare Tunnel (Optional)
# ============================================
# Enable with: docker compose --profile cloudflare up
# Get your token from: https://dash.cloudflare.com/get-started
CLOUDFLARE_TUNNEL_TOKEN=""

# ============================================
# Notes
# ============================================
# - All secrets should be changed for production deployments
# - Use strong passwords for POSTGRES_PASSWORD
# - Store secrets securely (e.g., Docker secrets, vault)
# - Never commit .env.docker to version control
