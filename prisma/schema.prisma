generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model District {
  code       String     @id
  name       String
  nameEn     String?
  region     String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  nameSc     String?
  nameTc     String?
  facilities Facility[]
}

model FacilityGroup {
  code       String         @id
  name       String
  nameEn     String?
  nameTc     String?
  nameSc     String?
  icon       String?
  seq        Int            @default(0)
  isFree     Boolean        @default(false)
  isVisible  Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  facilities FacilityType[]
}

model FacilityType {
  code      String        @id
  groupCode String
  name      String
  nameEn    String?
  nameTc    String?
  nameSc    String?
  icon      String?
  seq       Int           @default(0)
  isFree    Boolean       @default(false)
  isVisible Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  group     FacilityGroup @relation(fields: [groupCode], references: [code])
  sessions  Session[]
}

model ScheduledCrawlRun {
  id             String     @id @default(cuid())
  status         JobStatus  @default(RUNNING)
  daysToProcess  String[]
  totalDays      Int
  completedDays  String[]   @default([])
  failedDays     Json       @default("[]")
  currentDay     String?
  startedAt      DateTime   @default(now())
  completedAt    DateTime?
  lastActivityAt DateTime   @default(now())
  crawlJobs      CrawlJob[]

  @@index([status, startedAt])
}

model CrawlJob {
  id             String             @id @default(cuid())
  status         JobStatus          @default(PENDING)
  distCode       String
  faCode         String
  playDate       String
  startedAt      DateTime           @default(now())
  completedAt    DateTime?
  errorMessage   String?
  scheduledRunId String?
  scheduledRun   ScheduledCrawlRun? @relation(fields: [scheduledRunId], references: [id])
  results        CrawlResult[]
  sessions       Session[]

  @@index([status, startedAt])
  @@index([playDate])
  @@index([scheduledRunId])
}

model CrawlResult {
  id           String   @id @default(cuid())
  crawlJobId   String
  venueCount   Int
  sessionCount Int
  rawData      Json
  createdAt    DateTime @default(now())
  crawlJob     CrawlJob @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)

  @@index([crawlJobId])
}

model Facility {
  id             String    @id
  name           String
  nameEn         String?
  imageUrl       String
  districtCode   String
  districtName   String
  districtNameEn String?
  lastCrawlAt    DateTime  @default(now())
  districtNameSc String?
  districtNameTc String?
  nameSc         String?
  nameTc         String?
  district       District  @relation(fields: [districtCode], references: [code])
  sessions       Session[]

  @@index([districtCode])
  @@index([lastCrawlAt])
}

model Session {
  id                 String       @id
  crawlJobId         String
  venueId            String
  facilityCode       String
  facilityTypeName   String
  facilityTypeNameEn String
  facilityVRId       String
  date               DateTime
  startTime          String
  endTime            String
  timePeriod         TimePeriod
  available          Boolean
  isPeakHour         Boolean
  isOpen             Boolean
  createdAt          DateTime     @default(now())
  facilityTypeNameSc String?
  facilityTypeNameTc String?

  // Verification tracking fields
  lastVerifiedAt     DateTime?    // Last time availability was verified
  verifiedBy         VerificationSource? // Source of last verification (CRAWL or USER)
  lastAvailableAt    DateTime?    // Last time session was confirmed available

  crawlJob           CrawlJob     @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)
  facilityType       FacilityType @relation(fields: [facilityCode], references: [code])
  venue              Facility     @relation(fields: [venueId], references: [id])
  watchers           Watcher[]

  @@unique([venueId, facilityCode, date, startTime])
  @@index([crawlJobId])
  @@index([date])
  @@index([available])
  @@index([venueId, date])
  @@index([date, available])
  @@index([date, facilityCode])
  @@index([lastVerifiedAt])
  @@index([available, lastVerifiedAt])
}

model DeadLetterEntry {
  id            String    @id @default(cuid())
  faCode        String
  date          DateTime  @db.Date
  distCode      String
  error         String
  errorType     String?
  statusCode    Int?
  attempts      Int       @default(1)
  maxAttempts   Int       @default(3)
  firstFailedAt DateTime  @default(now())
  lastFailedAt  DateTime  @default(now())
  nextRetryAt   DateTime?
  resolvedAt    DateTime?
  status        DLQStatus @default(PENDING)
  jobId         String?
  metadata      Json?

  @@unique([faCode, date, distCode])
  @@index([status, nextRetryAt])
  @@index([date, status])
  @@index([lastFailedAt])
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum TimePeriod {
  MORNING
  AFTERNOON
  EVENING
}

enum DLQStatus {
  PENDING
  RETRYING
  RESOLVED
  PERMANENT
}

enum VerificationSource {
  CRAWL
  USER
}

// ============================================
// Browser Session (Anonymous User Tracking)
// ============================================

model BrowserSession {
  id        String         @id @default(cuid())
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  expiresAt DateTime       // Cookie expiry (180 days default)

  watchers  Watcher[]
  settings  UserSettings?

  @@index([expiresAt])
}

// ============================================
// Watch Scheduler Models
// ============================================

model Watcher {
  id                String         @id @default(cuid())
  browserSessionId  String         // FK to BrowserSession (anonymous user)
  targetSessionId   String?        // FK to Session (facility booking being watched, nullable if deleted)
  webhookUrl        String?        // User's callback webhook URL (required for new watchers)

  // Watch criteria (denormalized for query performance)
  venueId           String
  facilityCode      String
  date              DateTime       @db.Date
  startTime         String
  endTime           String

  // Status & metadata
  status            WatchStatus    @default(ACTIVE)

  // Statistics
  totalHits         Int            @default(0)
  lastHitAt         DateTime?
  notifiedAt        DateTime?      // Last notification timestamp

  // Timestamps
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  expiresAt         DateTime       // Auto-expire after date passes (required)

  // Relations
  browserSession    BrowserSession @relation(fields: [browserSessionId], references: [id], onDelete: Cascade)
  targetSession     Session?       @relation(fields: [targetSessionId], references: [id], onDelete: SetNull)
  hits              WatchHit[]

  @@index([browserSessionId, status])
  @@index([status, expiresAt])
  @@index([venueId, date])
  @@index([expiresAt])
  @@unique([browserSessionId, venueId, facilityCode, date, startTime])
}

model WatchHit {
  id                String    @id @default(cuid())
  watcherId         String

  // Hit details
  becameAvailable   Boolean   @default(true) // true=became available, false=became unavailable
  available         Boolean   // Current availability state
  checkedAt         DateTime  @default(now())

  // Notification status
  notificationSent  Boolean   @default(false)
  notificationError String?

  // Relations
  watcher           Watcher   @relation(fields: [watcherId], references: [id], onDelete: Cascade)

  @@index([watcherId, checkedAt])
  @@index([checkedAt])
}

model UserSettings {
  id                  String         @id @default(cuid())
  browserSessionId    String         @unique // FK to BrowserSession

  // Webhook configuration
  webhookUrl          String?
  webhookEnabled      Boolean        @default(false)

  // Notification preferences
  notifyOnAvailable   Boolean        @default(true)
  notifyOnUnavailable Boolean        @default(false)
  quietHoursStart     String?        // HH:MM format
  quietHoursEnd       String?        // HH:MM format

  // Timestamps
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Relations
  browserSession      BrowserSession @relation(fields: [browserSessionId], references: [id], onDelete: Cascade)
}

enum WatchStatus {
  ACTIVE
  PAUSED
  EXPIRED
  DELETED
}

model AvailabilityStats {
  id           String          @id @default(cuid())
  entityType   StatsEntityType // DATE, DISTRICT, CENTER, FACILITY
  entityCode   String          // date string, district code, center id, facility code
  date         DateTime        @db.Date
  priceType    String          @default("Paid") // "Paid" or "Free"
  
  // Stats
  totalSessions     Int   @default(0)
  availableSessions Int   @default(0)
  
  updatedAt    DateTime  @updatedAt
  
  @@unique([entityType, entityCode, date, priceType])
  @@index([date, entityType, priceType])
  @@index([entityType, priceType])
}

enum StatsEntityType {
  DATE
  DISTRICT
  CENTER
  FACILITY
}
