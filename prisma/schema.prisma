generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ============================================

// Crawler Models
// ============================================

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum TimePeriod {
  MORNING
  AFTERNOON
  EVENING
}

// Scheduled runs (for multi-day tracking)
model ScheduledCrawlRun {
  id              String   @id @default(cuid())
  status          JobStatus @default(RUNNING)
  
  // Configuration snapshot
  daysToProcess   String[]  // ["2025-01-14", "2025-01-15", ...]
  totalDays       Int
  
  // Progress tracking
  completedDays   String[]  @default([])
  failedDays      Json      @default("[]")  // [{"date": "2025-01-16", "error": "...", "attempts": 2}]
  currentDay      String?
  
  // Timing
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  lastActivityAt  DateTime  @default(now())
  
  // Related jobs
  crawlJobs       CrawlJob[]
  
  @@index([status, startedAt])
}

model CrawlJob {
  id           String    @id @default(cuid())
  status       JobStatus @default(PENDING)
  distCode     String
  faCode       String
  playDate     String
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  errorMessage String?

  results      CrawlResult[]
  sessions     Session[]

  scheduledRunId  String?
  scheduledRun    ScheduledCrawlRun? @relation(fields: [scheduledRunId], references: [id])

  @@index([status, startedAt])
  @@index([playDate])
  @@index([scheduledRunId])
}

model CrawlResult {
  id           String   @id @default(cuid())
  crawlJobId   String
  crawlJob     CrawlJob @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)

  venueCount   Int
  sessionCount Int
  rawData      Json

  createdAt    DateTime @default(now())

  @@index([crawlJobId])
}


model Facility {
  id           String       @id
  name         String
  imageUrl     String
  districtCode String
  districtName String
  lastCrawlAt  DateTime     @default(now())

  sessions     Session[]

  @@index([districtCode])
  @@index([lastCrawlAt])
}

model Session {
  id                  String     @id
  crawlJobId          String
  crawlJob            CrawlJob   @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)

  venueId             String
  venue               Facility   @relation(fields: [venueId], references: [id])

  facilityTypeId      Int
  facilityTypeName    String
  facilityTypeNameEn  String
  facilityCode        String
  facilityVRId        String

  date                DateTime
  startTime           String
  endTime             String
  timePeriod          TimePeriod

  available           Boolean
  isPeakHour          Boolean
  isOpen              Boolean

  createdAt           DateTime   @default(now())

  @@unique([venueId, facilityTypeId, date, startTime])
  @@index([crawlJobId])
  @@index([date])
  @@index([available])
  @@index([venueId, date])
}